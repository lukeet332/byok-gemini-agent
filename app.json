{
  "expo": {
    "name": "Fraude",
    "slug": "byok-gemini-agent",
    "scheme": "fraude",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0f14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lukeet332.byokgeminiagent"
    },
    "android": {
      "package": "com.lukeet332.byokgeminiagent",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.QUERY_ALL_PACKAGES",
        "com.termux.permission.RUN_COMMAND",
        "android.permission.MANAGE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0f14"
      },
      "intentFilters": [
        {
          "action": "android.intent.action.SEND",
          "category": ["android.intent.category.DEFAULT"],
          "data": [{ "mimeType": "text/plain" }]
        }
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow the app to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow the app to recognise your speech for voice input.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Fraude to attach photos to your messages."
        }
      ],
      "expo-notifications",
      ["expo-contacts", { "contactsPermission": "Allow Fraude to read your contacts to find people to message or call." }],
      ["expo-calendar", { "calendarPermission": "Allow Fraude to read your calendar to help organise your day." }],
      ["expo-location", { "locationWhenInUsePermission": "Allow Fraude to use your location for nearby / where-am-I tasks." }]
    ]
  }
}
