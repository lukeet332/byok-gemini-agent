<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="expo.modules.shellexec" >

    <uses-sdk android:minSdkVersion="24" />

    <application>

        <!-- Required for the Shizuku binder to reach this app. -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="dollar_openBracket_applicationId_closeBracket.shizuku"
            android:enabled="true"
            android:exported="true"
            android:multiprocess="false"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <!-- App-agnostic UI automation; the user enables it in Accessibility settings. -->
        <service
            android:name="expo.modules.shellexec.FraudeAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE" >
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/fraude_accessibility_config" />
        </service>
    </application>

</manifest>